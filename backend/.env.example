# Environment Variables Template
# Copy to .env and fill with your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database (Supabase PostgreSQL)
DB_HOST=aws-0-us-west-2.pooler.supabase.com
DB_USER=postgres.ixhmevgiodlsviiyihom
DB_PASSWORD=your-password-here
DB_NAME=postgres
DB_PORT=6543
DB_SSL=true

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=8h
RESET_TOKEN_SECRET=your-reset-token-secret-here

# App Configuration
APP_PUBLIC_URL=http://localhost:5173

# Email Configuration - Gmail API (OAuth2)
# Requiere Gmail API habilitada y refresh token (ver pasos en la guia del chat)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Remitente (debe ser el mismo Gmail o un alias autorizado)
GMAIL_FROM=your-email@gmail.com

# Alternativa compatible:
# MAIL_FROM="CuponX <correo@dominio.com>"
